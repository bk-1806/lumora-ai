# Railway Environment Variable Configuration Template
# ----------------------------------------------------------------------
# IMPORTANT: DO NOT commit your actual .env file.
# Copy this file to .env locally, or add these keys to the Railway Dashboard Variables.

# Supabase Connection (Required for Saving Analysis and Resume History)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Production Port (Managed automatically by Railway, set locally to 8000)
PORT=8000
